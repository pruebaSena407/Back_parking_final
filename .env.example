# Opción 1: Variable única (RECOMENDADO para Render)
DATABASE_URL=mysql+pymysql://usuario:contraseña@host:puerto/dbname?ssl_mode=REQUIRED

# Opción 2: Variables individuales (si no tienes DATABASE_URL)
DB_USER=usuario
DB_PASSWORD=contraseña
DB_HOST=host
DB_PORT=3306
DB_NAME=nombrebasedatos
DB_SSL_MODE=REQUIRED
DB_SSL_CA=/ruta/al/certificado.pem

# Configuración de la aplicación (opcional)
FLASK_ENV=production
SECRET_KEY=tu-clave-secreta-aqui
